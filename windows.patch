+        index += 1;
+      }
+      let digits_start = index;
+      while index < bytes.len() && bytes[index].is_ascii_digit() {
+        index += 1;
+      }
+      if digits_start == index {
+        index = exp_start;
+      }
+    }
+
+    input[start..index].parse::<f64>().ok().map(|num| (num, index))
+  }
